             COMPONENTES FRONTEND
        ───────────────────────────────────────── -->
        <mxCell id="frontend-pages" value="&lt;b&gt;Páginas&lt;/b&gt;&lt;br&gt;• Login (Basic / JWT)&lt;br&gt;• Episodes&lt;br&gt;• NewEpisode&lt;br&gt;• ClinicalNote" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#01579b;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
