        <!-- ─────────────────────────────────────────
             PATRONES ARQUITECTÓNICOS
        ───────────────────────────────────────── -->
        <mxCell id="patterns" value="&lt;b&gt;Patrones de Diseño&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#cc9900;verticalAlign=top;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="280" height="430" as="geometry" />
        </mxCell>

        <mxCell id="pattern1" value="&lt;b&gt;1. Arquitectura Tabla Única&lt;/b&gt;&lt;br&gt;• Campos indexados para búsquedas&lt;br&gt;• JSON completo en data_json&lt;br&gt;• Antecedentes en JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc9900;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="480" width="240" height="65" as="geometry" />
        </mxCell>

        <mxCell id="pattern2" value="&lt;b&gt;2. Patrón Outbox&lt;/b&gt;&lt;br&gt;• Garantiza entrega de mensajes&lt;br&gt;• Reintentos automáticos (max 5)&lt;br&gt;• author_user_id para trazabilidad" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc9900;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="555" width="240" height="65" as="geometry" />
        </mxCell>

        <mxCell id="pattern3" value="&lt;b&gt;3. Sincronización Bidireccional&lt;/b&gt;&lt;br&gt;• Downstream: episodios central → local&lt;br&gt;• Upstream: HL7 local → central&lt;br&gt;• Actualización automática de IDs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc9900;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="630" width="240" height="65" as="geometry" />
        </mxCell>

        <mxCell id="pattern4" value="&lt;b&gt;4. Offline-First&lt;/b&gt;&lt;br&gt;• Operación autónoma sin conexión&lt;br&gt;• Sync automática al reconectar&lt;br&gt;• Almacenamiento local completo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc9900;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="705" width="240" height="65" as="geometry" />
        </mxCell>

        <mxCell id="pattern5" value="&lt;b&gt;5. User Sync con PBKDF2 central&lt;/b&gt;&lt;br&gt;• Usuarios importados del central&lt;br&gt;• Hash pbkdf2central compatible TrakCare&lt;br&gt;• central_sync_hash evita escrituras&lt;br&gt;• bcrypt para usuarios locales" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#006600;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="780" width="240" height="80" as="geometry" />
        </mxCell>

