        </mxCell>

        <mxCell id="pattern2" value="&lt;b&gt;2. Patrón Outbox&lt;/b&gt;&lt;br&gt;• Garantiza entrega de mensajes&lt;br&gt;• Reintentos automáticos (max 5)&lt;br&gt;• Procesamiento asíncrono" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc9900;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
