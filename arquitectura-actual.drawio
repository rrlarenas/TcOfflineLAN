        </mxCell>

        <mxCell id="pattern3" value="&lt;b&gt;3. Sincronización Bidireccional&lt;/b&gt;&lt;br&gt;• Downstream: Central → Local (GET)&lt;br&gt;• Upstream: Local → Central (POST HL7)&lt;br&gt;• Actualización automática de IDs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc9900;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
