             SERVIDOR CENTRAL
        ───────────────────────────────────────── -->
        <mxCell id="central-server" value="&lt;b&gt;Servidor Central TrakCare&lt;/b&gt;&lt;br&gt;(InterSystems Caché / IRIS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;verticalAlign=top;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="1260" y="200" width="280" height="500" as="geometry" />
        </mxCell>

        <mxCell id="central-endpoints" value="&lt;b&gt;API REST Endpoints&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;GET&lt;/b&gt; /apirest/externos/obtenerDatos&lt;br&gt;• Episodios completos con JSON&lt;br&gt;• Filtros personalizados por usuario&lt;br&gt;&lt;br&gt;&lt;b&gt;POST&lt;/b&gt; /apirest/externos/hl7inbound&lt;br&gt;• Recibe mensajes HL7 v2.3&lt;br&gt;• ADT^A28 - Info paciente&lt;br&gt;• ADT^A01 - Admisión&lt;br&gt;• ORU^R01 - Notas clínicas&lt;br&gt;• Responde con pid + enctid&lt;br&gt;&lt;br&gt;&lt;b&gt;GET&lt;/b&gt; /apirest/externos/obtenerUsuarios&lt;br&gt;• Lista de usuarios con credenciales&lt;br&gt;• password (PBKDF2 output)&lt;br&gt;• passwordSalt (base64)&lt;br&gt;• active (Y/N)&lt;br&gt;&lt;br&gt;&lt;b&gt;Auth:&lt;/b&gt; Basic Auth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#10739e;align=left;verticalAlign=top;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="1280" y="235" width="240" height="440" as="geometry" />
        </mxCell>

