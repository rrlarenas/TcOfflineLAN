        <mxCell id="pattern4" value="&lt;b&gt;4. Offline-First&lt;/b&gt;&lt;br&gt;• Operación autónoma sin conexión&lt;br&gt;• Sincronización automática al reconectar&lt;br&gt;• Almacenamiento local completo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc9900;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
