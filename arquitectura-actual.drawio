        <mxCell id="pattern1" value="&lt;b&gt;1. Arquitectura de Tabla Única&lt;/b&gt;&lt;br&gt;• Campos indexados para búsquedas&lt;br&gt;• JSON completo en data_json&lt;br&gt;• Antecedentes incluidos en JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc9900;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
