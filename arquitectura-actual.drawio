          <mxGeometry x="480" y="230" width="260" height="110" as="geometry" />
        </mxCell>

        <mxCell id="bgtasks-local" value="&lt;b&gt;Background Tasks&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Health Check (8s)&lt;br&gt;• Downstream Sync (60s)&lt;br&gt;• Upstream Sync (10s)&lt;br&gt;• Outbox Processor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="355" width="260" height="155" as="geometry" />
        </mxCell>

        <!-- SQLite -->
        <mxCell id="sqlite-box" value="&lt;b&gt;SQLite Database&lt;/b&gt;&lt;br&gt;(local.db)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="460" y="570" width="300" height="220" as="geometry" />
        </mxCell>

        <mxCell id="sqlite-tables" value="&lt;b&gt;Tablas&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;users&lt;/b&gt; - Usuarios (bcrypt o pbkdf2central)&lt;br&gt;• &lt;b&gt;episodes&lt;/b&gt; - Episodios + JSON completo&lt;br&gt;• &lt;b&gt;clinical_notes&lt;/b&gt; - Notas clínicas&lt;br&gt;• &lt;b&gt;outbox_events&lt;/b&gt; - Cola de mensajes HL7&lt;br&gt;• &lt;b&gt;sync_state&lt;/b&gt; - Configuración global&lt;br&gt;&lt;br&gt;&lt;b&gt;ORM:&lt;/b&gt; SQLAlchemy · &lt;b&gt;Migraciones:&lt;/b&gt; Alembic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="480" y="600" width="260" height="175" as="geometry" />
        </mxCell>

        <!-- ─────────────────────────────────────────
             BACKEND LAN (backend_lan/)
        ───────────────────────────────────────── -->
        <mxCell id="backend-lan-box" value="&lt;b&gt;Backend LAN — backend_lan/&lt;/b&gt;&lt;br&gt;(http://0.0.0.0:8000 · Docker)&lt;br&gt;&lt;i&gt;PostgreSQL · JWT Bearer&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#006600;verticalAlign=top;fontSize=12;fontStyle=1;" vertex="1" parent="1">
