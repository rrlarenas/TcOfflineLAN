        </mxCell>

        <mxCell id="fastapi-lan" value="&lt;b&gt;FastAPI Application&lt;/b&gt;&lt;br&gt;&lt;br&gt;• CORS Middleware&lt;br&gt;• OAuth2 Password Flow&lt;br&gt;• JWT Bearer (HS256, 480 min)&lt;br&gt;• REST Endpoints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="135" width="280" height="90" as="geometry" />
        </mxCell>

        <mxCell id="routers-lan" value="&lt;b&gt;Routers (mismos que app/)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• /auth/token - Login JWT&lt;br&gt;• /episodes&lt;br&gt;• /notes&lt;br&gt;• /sync&lt;br&gt;• /settings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="240" width="280" height="110" as="geometry" />
        </mxCell>

        <mxCell id="bgtasks-lan" value="&lt;b&gt;Background Tasks&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Health Check (8s)&lt;br&gt;• Downstream Sync — episodios (60s)&lt;br&gt;• &lt;b&gt;User Sync — usuarios del central (60s)&lt;/b&gt;&lt;br&gt;• Upstream Sync (10s)&lt;br&gt;• Outbox Processor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="365" width="280" height="130" as="geometry" />
        </mxCell>

        <mxCell id="user-sync-detail" value="&lt;b&gt;CentralUserSync&lt;/b&gt;&lt;br&gt;&lt;i&gt;backend_lan/app/sync_service.py&lt;/i&gt;&lt;br&gt;&lt;br&gt;1. GET usuarios del central (Basic Auth)&lt;br&gt;2. Calcular central_sync_hash (SHA-256)&lt;br&gt;3. Si cambió → upsert usuario local&lt;br&gt;4. Sanitizar password: NUL/binary → base64&lt;br&gt;5. Almacenar como &lt;b&gt;pbkdf2central:{salt}:{hash}&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Verificacion login:&lt;/b&gt;&lt;br&gt;PBKDF2-SHA1 · 2500 iters · dkLen=32&lt;br&gt;&lt;i&gt;backend_lan/app/auth_utils.py&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="508" width="280" height="170" as="geometry" />
        </mxCell>

        <!-- PostgreSQL -->
        <mxCell id="postgres-box" value="&lt;b&gt;PostgreSQL Database&lt;/b&gt;&lt;br&gt;(pool_size=10, max_overflow=20)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0066aa;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="840" y="820" width="320" height="210" as="geometry" />
        </mxCell>

        <mxCell id="postgres-tables" value="&lt;b&gt;Tablas (timezone-aware)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;users&lt;/b&gt; - Usuarios + central_sync_hash&lt;br&gt;• &lt;b&gt;episodes&lt;/b&gt; - Episodios + JSON completo&lt;br&gt;• &lt;b&gt;clinical_notes&lt;/b&gt; - Notas clínicas&lt;br&gt;• &lt;b&gt;outbox_events&lt;/b&gt; + author_user_id&lt;br&gt;• &lt;b&gt;sync_state&lt;/b&gt; - Config global&lt;br&gt;&lt;br&gt;&lt;b&gt;ORM:&lt;/b&gt; SQLAlchemy · &lt;b&gt;Migraciones:&lt;/b&gt; Alembic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0066aa;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="850" width="280" height="160" as="geometry" />
        </mxCell>

