# TrakCare Offline LAN - Backend Configuration
# Copy this file to .env and fill in the values

# ─── PostgreSQL Setup (run once as postgres superuser) ────────────────────────
# psql -U postgres -c "CREATE DATABASE tcoffline;"
# psql -U postgres -c "CREATE USER tcoffline WITH PASSWORD 'tcoffline';"
# psql -U postgres -c "GRANT ALL PRIVILEGES ON DATABASE tcoffline TO tcoffline;"
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://tcoffline:tcoffline@100.66.11.101:5432/tcoffline

# JWT secret key - CHANGE THIS IN PRODUCTION (use a long random string)
SECRET_KEY=change-this-in-production-use-a-long-random-string

# JWT token expiry in minutes (default: 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Central server URL
CENTRAL_URL=http://demo01.tcdb.vtas.cl.intersystems.com

# Central API endpoints
CENTRAL_API_ENDPOINT=/demo01/tcoffline/getData
CENTRAL_HL7_ENDPOINT=/demo01/tcoffline/hl7inbound
CENTRAL_USERS_ENDPOINT=/demo01/tcoffline/getUsers

# Central API credentials
CENTRAL_API_USERNAME=demo
CENTRAL_API_PASSWORD=demodemo

# Sync intervals (seconds)
HEALTH_CHECK_INTERVAL=8
DOWNSTREAM_SYNC_INTERVAL=60
UPSTREAM_SYNC_INTERVAL=10
MAX_RETRIES=5

# Default language (es/en)
DEFAULT_LANGUAGE=es

# Environment
ENVIRONMENT=production
